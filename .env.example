# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- GCP ---
GCP_PROJECT_ID=gliq-502820
GCP_REGION=us-central1
# Path to service account key. On GCP VMs, prefer the attached service account
# and leave this unset so Application Default Credentials are used.
# GOOGLE_APPLICATION_CREDENTIALS=/etc/gliq/sa-key.json

# --- Pub/Sub (messaging) ---
PUBSUB_TOPIC_SCORING_REQUESTED=scoring-requested
PUBSUB_SUB_SCORING_REQUESTED=scoring-requested-sub
PUBSUB_TOPIC_SCORING_COMPLETED=scoring-completed
PUBSUB_SUB_SCORING_COMPLETED=scoring-completed-sub
# Poison messages land here after 5 failed deliveries.
PUBSUB_DEAD_LETTER_TOPIC=gliq-dead-letter

# --- Cloud Storage (report artifacts) ---
GCS_ARTIFACTS_BUCKET=

# NOTE: don't fill the values above by hand — after `pulumi up`, run
#   python3 infra/env-from-stack.py
# to write them into .env straight from the stack outputs.

# --- Cloud SQL (database) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=greenlightiq
DB_USER=gliq
DB_PASSWORD=

# --- Memorystore (caching) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
CACHE_TTL_SECONDS=3600

# --- Component A: extraction ---
# deterministic | fixture | anthropic | gemini
#
# `deterministic` is the Part 1 extractor and the default: it matches the
# document against the tags and genres that occur in the corpus, needs no key
# and no network, and is the reproducible CONTROL the Part 2 LLM path is
# measured against.
#
# `fixture` returns a canned pitch_profile REGARDLESS OF INPUT. Use it to
# develop and test Components B and C — never to evaluate a real pitch.
#
# ⚠️ This variable is not written to /etc/gliq/gliq.env by
# infra/env-from-stack.py, so on the VMs the default in shared/config.py is what
# takes effect. Setting it here changes local runs only.
LLM_PROVIDER=deterministic

# ⏳ Part 2 — unused until the LLM providers land.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# --- Component A: HTTP ---
# ⚠️ The listen address is NOT configurable here. The systemd unit binds
# uvicorn to 127.0.0.1:8000 deliberately — nginx is the public path, and
# binding 0.0.0.0 would expose uvicorn directly on the VM's external IP.
# (INTAKE_HOST/INTAKE_PORT used to sit here; both were read by nothing.)
PUBLIC_URL=https://greenlightiq.fredt.io

# --- Optional: SteamSpy live enrichment ---
# Rate limits: 1 req/sec most endpoints, 1 req/60s for the `all` endpoint.
STEAMSPY_ENABLED=false
