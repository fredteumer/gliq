# Secrets — never commit
.env
.env.*
!.env.example
*-key.json
*credentials*.json
service-account*.json

# Claude Code / agent tooling — personal settings only
.claude/settings.local.json
.claude/*.local.json

# Steam dataset — separately licensed, fetched by data/etl at setup
data/raw/*
!data/raw/.gitkeep

# Session continuity — local working memory, never committed.
# See "Session continuity" in AGENTS.md.
WIP*.md

# Generated reports and artifacts
out/
reports/
*.pdf
!docs/**/*.pdf

# Pulumi
# Stack config is NOT committed. It holds `pulumi config set --secret` values
# (currently the Tailscale auth key) encrypted with the stack passphrase — and
# a weak passphrase in a public AGPL repo is a published secret. Reproducibility
# is handled by documenting required config keys in docs/DEPLOYMENT.md instead.
Pulumi.*.yaml
!Pulumi.yaml
.pulumi/

# Node (infra/pulumi)
node_modules/
*.tsbuildinfo

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
