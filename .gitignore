# Secrets — never commit
.env
.env.*
!.env.example
*-key.json
*credentials*.json
service-account*.json

# Claude Code / agent tooling — personal settings only
.claude/settings.local.json
.claude/*.local.json

# Steam dataset — separately licensed, fetched by data/etl at setup
data/raw/*
!data/raw/.gitkeep

# Generated reports and artifacts
out/
reports/
*.pdf
!docs/**/*.pdf

# Pulumi
# Stack config IS committed: secret values are encrypted with the stack's
# passphrase, and without it the stack is not reproducible from the repo.
# Never `pulumi config set` a secret without the --secret flag.
.pulumi/

# Node (infra/pulumi)
node_modules/
*.tsbuildinfo

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
